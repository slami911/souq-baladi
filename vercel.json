{
  "services": {
    "souq-baladi-frontend": {
      "root": ".",
      "framework": "nextjs",
      "installCommand": "npm install --include=dev",
      "buildCommand": "npm run build"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "souq-baladi-frontend"
      }
    }
  ]
}
